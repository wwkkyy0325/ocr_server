# -*- coding: utf-8 -*-
# 文件说明：
# - 作用：悬浮结果窗口，复用主窗口的 ImageViewer 和 ResultTableWidget
# - 核心实现：将主窗口的核心 UI 组件（图片预览、表格结果、文本结果）整合到悬浮窗
# - 关联关系：由 ScreenshotController 使用，与主窗口共享相同的 UI 组件和逻辑
from PyQt5.QtWidgets import QWidget, QVBoxLayout, QTextEdit, QPushButton, QHBoxLayout, QLabel, QApplication, QSplitter, QFrame
from PyQt5.QtCore import Qt, QPoint, pyqtSignal
from PyQt5.QtGui import QCursor

# 导入主窗口的核心组件
try:
    from app.ui.widgets.image_viewer import ImageViewer
    from app.ui.widgets.result_table_widget import ResultTableWidget
    COMPONENTS_AVAILABLE = True
except ImportError:
    COMPONENTS_AVAILABLE = False
    print("警告：无法导入核心 UI 组件，悬浮窗功能将受限")

class FloatingResultWidget(QWidget):
    restore_requested = pyqtSignal()

    def __init__(self, parent=None):
        super().__init__(parent)
        # Frameless, Always on Top, Tool window (no taskbar entry)
        self.setWindowFlags(Qt.FramelessWindowHint | Qt.WindowStaysOnTopHint | Qt.Tool)
        self.setAttribute(Qt.WA_TranslucentBackground)
        
        # 存储对核心组件的引用
        self.image_viewer = None
        self.result_table = None
        self.text_display = None
        
        # 初始化 UI（如果组件可用）
        if COMPONENTS_AVAILABLE:
            self._init_ui()
        else:
            self._init_fallback_ui()
        
        self.resize(800, 600)  # 更大的默认尺寸以容纳多个组件
        
        # Dragging logic
        self.old_pos = None
        self.user_moved = False

    def _init_ui(self):
        """初始化完整 UI（复用主窗口组件）"""
        # Main layout
        main_layout = QVBoxLayout(self)
        main_layout.setContentsMargins(0, 0, 0, 0)
        
        # Container widget for background styling
        self.container = QWidget()
        self.container.setObjectName("Container")
        self.container.setStyleSheet("""
            QWidget#Container {
                background-color: rgba(0, 0, 0, 200);
                border-radius: 8px;
                border: 1px solid rgba(255, 255, 255, 100);
            }
        """)
        container_layout = QVBoxLayout(self.container)
        container_layout.setContentsMargins(8, 5, 8, 8)
        
        # Title bar
        title_bar = QHBoxLayout()
        title_bar.setContentsMargins(0, 0, 0, 0)
        
        self.lbl_title = QLabel("截屏识别结果")
        self.lbl_title.setStyleSheet("color: white; font-weight: bold; font-family: Microsoft YaHei; font-size: 14px;")
        
        btn_restore = QPushButton("❐")
        btn_restore.setFixedSize(24, 24)
        btn_restore.setCursor(Qt.PointingHandCursor)
        btn_restore.setToolTip("恢复主界面 / Restore Main Window")
        btn_restore.clicked.connect(self.restore_requested.emit)
        btn_restore.setStyleSheet("""
            QPushButton {
                background-color: transparent; 
                color: white; 
                border: none; 
                font-size: 16px;
                font-weight: bold;
            }
            QPushButton:hover { color: #55ff55; }
        """)

        btn_close = QPushButton("×")
        btn_close.setFixedSize(24, 24)
        btn_close.setCursor(Qt.PointingHandCursor)
        btn_close.clicked.connect(self.hide)
        btn_close.setStyleSheet("""
            QPushButton {
                background-color: transparent; 
                color: white; 
                border: none; 
                font-size: 18px;
                font-weight: bold;
            }
            QPushButton:hover { color: #ff5555; }
        """)
        
        title_bar.addWidget(self.lbl_title)
        title_bar.addStretch()
        title_bar.addWidget(btn_restore)
        title_bar.addWidget(btn_close)
        
        container_layout.addLayout(title_bar)
        
        # 添加分隔线
        separator = QFrame()
        separator.setFrameShape(QFrame.HLine)
        separator.setFrameShadow(QFrame.Sunken)
        separator.setStyleSheet("background-color: rgba(255, 255, 255, 50);")
        container_layout.addWidget(separator)
        
        # 使用分割器来组织不同区域
        splitter = QSplitter(Qt.Vertical)
        splitter.setHandleWidth(2)
        splitter.setStyleSheet("QSplitter::handle { background-color: rgba(255, 255, 255, 30); }")
        
        # 1. 图片预览区（复用 ImageViewer）
        if hasattr(self, 'image_viewer') or True:  # 总是创建
            self.image_viewer = ImageViewer()
            self.image_viewer.setMinimumHeight(200)
            splitter.addWidget(self.image_viewer)
        
        # 2. 右侧/下侧结果区（文本 + 表格）
        result_container = QWidget()
        result_layout = QVBoxLayout(result_container)
        result_layout.setContentsMargins(0, 0, 0, 0)
        result_layout.setSpacing(5)
        
        # 2a. 文本结果显示
        self.text_display = QTextEdit()
        self.text_display.setReadOnly(True)
        self.text_display.setStyleSheet("""
            QTextEdit {
                background-color: rgba(0, 0, 0, 100);
                color: white;
                border: 1px solid rgba(255, 255, 255, 30);
                border-radius: 4px;
                font-size: 13px;
                font-family: Microsoft YaHei;
                padding: 5px;
            }
            QTextEdit::selection {
                background-color: #0078d7;
                color: white;
            }
        """)
        self.text_display.setMinimumHeight(100)
        result_layout.addWidget(self.text_display)
        
        # 2b. 表格结果显示（复用 ResultTableWidget）
        if hasattr(self, 'result_table') or True:  # 总是创建
            self.result_table = ResultTableWidget()
            self.result_table.setMinimumHeight(150)
            result_layout.addWidget(self.result_table)
        
        splitter.addWidget(result_container)
        
        # 设置分割比例
        splitter.setStretchFactor(0, 1)  # 图片区
        splitter.setStretchFactor(1, 1)  # 结果区
        
        container_layout.addWidget(splitter)
        
        main_layout.addWidget(self.container)

    def _init_fallback_ui(self):
        """初始化简化版 UI（当核心组件不可用时）"""
        # 使用原来的简单布局
        layout = QVBoxLayout(self)
        layout.setContentsMargins(0, 0, 0, 0)
        
        self.container = QWidget()
        self.container.setObjectName("Container")
        self.container.setStyleSheet("""
            QWidget#Container {
                background-color: rgba(0, 0, 0, 200);
                border-radius: 8px;
                border: 1px solid rgba(255, 255, 255, 100);
            }
        """)
        container_layout = QVBoxLayout(self.container)
        container_layout.setContentsMargins(10, 5, 10, 10)
        
        # Title bar
        title_bar = QHBoxLayout()
        title_bar.setContentsMargins(0, 0, 0, 0)
        
        self.lbl_title = QLabel("OCR Result")
        self.lbl_title.setStyleSheet("color: white; font-weight: bold; font-family: Microsoft YaHei;")
        
        btn_restore = QPushButton("❐")
        btn_restore.setFixedSize(24, 24)
        btn_restore.clicked.connect(self.restore_requested.emit)
        
        btn_close = QPushButton("×")
        btn_close.setFixedSize(24, 24)
        btn_close.clicked.connect(self.hide)
        
        title_bar.addWidget(self.lbl_title)
        title_bar.addStretch()
        title_bar.addWidget(btn_restore)
        title_bar.addWidget(btn_close)
        container_layout.addLayout(title_bar)
        
        # Text Area
        self.text_edit = QTextEdit()
        self.text_edit.setReadOnly(False)
        container_layout.addWidget(self.text_edit)
        
        layout.addWidget(self.container)

    def set_text(self, text):
        """设置结果文本（兼容旧接口）"""
        if self.text_display:
            self.text_display.setPlainText(text)
        elif hasattr(self, 'text_edit'):
            self.text_edit.setPlainText(text)
        self.show()
        self.raise_()
        self.activateWindow()
        
        # If user hasn't moved the window, set to top-right of current screen
        if not self.user_moved:
            cursor_pos = QCursor.pos()
            screen_geo = QApplication.desktop().screenGeometry(cursor_pos)
            
            # Target: Top-Right (with some margin)
            target_x = screen_geo.right() - self.width() - 20
            target_y = screen_geo.top() + 50 # Leave some space for status bar or similar
            
            self.move(target_x, target_y)

    def show_loading(self):
        """显示加载状态"""
        if self.text_display:
            self.text_display.setPlainText("正在识别...\n\n请稍候")
        elif hasattr(self, 'text_edit'):
            self.text_edit.setPlainText("正在识别...\n\n请稍候")
        
        self.show()
        self.raise_()
        self.activateWindow()
        
        # 如果用户没有移动过窗口，设置到当前屏幕的右上角
        if not self.user_moved:
            cursor_pos = QCursor.pos()
            screen_geo = QApplication.desktop().screenGeometry(cursor_pos)
            
            target_x = screen_geo.right() - self.width() - 20
            target_y = screen_geo.top() + 50
            
            self.move(target_x, target_y)

    def show_result(self, text):
        """显示识别结果（兼容旧接口）"""
        if self.text_display:
            self.text_display.setPlainText(text)
        elif hasattr(self, 'text_edit'):
            self.text_edit.setPlainText(text)
        self.show()
        self.raise_()
        self.activateWindow()

    def display_image(self, image_path):
        """
        显示图片到预览框（复用主窗口逻辑）
        
        Args:
            image_path: 图片路径
        """
        if self.image_viewer and COMPONENTS_AVAILABLE:
            self.image_viewer.display_image(image_path)
            print(f"DEBUG [FloatingResultWidget] Image displayed: {image_path}")

    def set_ocr_results(self, items):
        """
        设置 OCR 识别结果（复用主窗口逻辑）
        
        Args:
            items: 标准化的 OCR 结果列表（与主窗口相同的格式）
        """
        if COMPONENTS_AVAILABLE:
            # 1. 更新图片标注（如果已显示图片）
            if self.image_viewer:
                self.image_viewer.set_ocr_results(items)
            
            # 2. 更新表格结果
            if self.result_table:
                # 提取表格信息
                table_cells = []
                has_table_info = False
                
                for item in items:
                    if item.get('table_info'):
                        has_table_info = True
                        cell = {
                            'text': item.get('text', ''),
                            'confidence': item.get('confidence', 0.0),
                            'table_info': item['table_info']
                        }
                        table_cells.append(cell)
                
                # 更新表格视图
                self.result_table.set_data(table_cells if has_table_info else [])
            
            # 3. 更新文本结果
            if self.text_display:
                # 从 items 中提取文本（按阅读顺序）
                if items and len(items) > 0:
                    # 如果有 box 坐标，按 y 坐标排序
                    if items[0].get('box'):
                        sorted_items = sorted(
                            items,
                            key=lambda r: (
                                r.get('box', [0, 0, 0, 0])[1],  # y1
                                r.get('box', [0, 0, 0, 0])[0]   # x1
                            )
                        )
                        text_lines = [r.get('text', '') for r in sorted_items if r.get('text', '').strip()]
                        text = "\n".join(text_lines)
                    else:
                        # 没有坐标，直接拼接
                        text = "\n".join([r.get('text', '') for r in items])
                    
                    self.text_display.setPlainText(text)
            
            print(f"DEBUG [FloatingResultWidget] OCR results displayed: {len(items)} items")

    def mousePressEvent(self, event):
        if event.button() == Qt.LeftButton:
            self.old_pos = event.globalPos()

    def mouseMoveEvent(self, event):
        if self.old_pos:
            delta = event.globalPos() - self.old_pos
            self.move(self.pos() + delta)
            self.old_pos = event.globalPos()
            self.user_moved = True # Mark as moved by user

    def mouseReleaseEvent(self, event):
        self.old_pos = None
